---
import BaseLayout from '../layouts/BaseLayout.astro';
import { inlineMd } from '../lib/inlineMd';
import { frontmatter as cvFrontmatter } from '../content/cv.md';

const cv = cvFrontmatter as {
  pdfHref: string;
  profile: string[];
  interests: string[];
  appointments: Entry[];
  industry: Entry[];
  education: Entry[];
  training: string[];
  skills: { label: string; value: string }[];
  grants: string[];
  languages: string[];
};

type Entry = {
  title: string;
  org: string;
  dates: string;
  location: string;
  bullets: string[];
};

const entrySections: { heading: string; entries: Entry[] }[] = [
  { heading: 'Academic appointments', entries: cv.appointments },
  { heading: 'Industry & Policy Experience', entries: cv.industry },
  { heading: 'Education', entries: cv.education },
];
---

<BaseLayout
  title="CV — Filip-Mihai Toma"
  description="Academic and industry experience, education, grants and skills of Filip-Mihai Toma, PhD."
>
  <div class="flex flex-wrap items-center justify-between gap-4">
    <h1 class="font-serif text-3xl font-semibold tracking-tight">Curriculum Vitae</h1>
    <a
      href={cv.pdfHref}
      class="inline-flex items-center gap-1.5 rounded-md border border-[color:var(--color-accent)]/30 dark:border-[color:var(--color-accent-dark)]/30 px-3 py-1.5 text-sm font-medium text-[color:var(--color-accent)] dark:text-[color:var(--color-accent-dark)] hover:bg-[color:var(--color-accent)]/5 dark:hover:bg-[color:var(--color-accent-dark)]/10 no-underline transition-colors"
      download
    >
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 4v12m0 0 4-4m-4 4-4-4M4 20h16" />
      </svg>
      Download PDF
    </a>
  </div>

  <section class="mt-10" aria-labelledby="research-profile">
    <h2 id="research-profile" class="font-serif text-xl font-semibold text-[color:var(--color-accent)] dark:text-[color:var(--color-accent-dark)]">
      Research profile
    </h2>
    <ul class="mt-3 list-disc space-y-1.5 pl-5 text-[color:var(--color-ink)]/90 dark:text-[color:var(--color-ink-dark)]/90">
      {cv.profile.map((p) => <li set:html={inlineMd(p)} />)}
    </ul>
  </section>

  <section class="mt-10" aria-labelledby="research-interests">
    <h2 id="research-interests" class="font-serif text-xl font-semibold text-[color:var(--color-accent)] dark:text-[color:var(--color-accent-dark)]">
      Research interests
    </h2>
    <ul class="mt-3 list-disc space-y-1.5 pl-5 text-[color:var(--color-ink)]/90 dark:text-[color:var(--color-ink-dark)]/90">
      {cv.interests.map((p) => <li set:html={inlineMd(p)} />)}
    </ul>
  </section>

  {entrySections.map((s) => (
    <section class="mt-10">
      <h2 class="font-serif text-xl font-semibold text-[color:var(--color-accent)] dark:text-[color:var(--color-accent-dark)]">
        {s.heading}
      </h2>
      <div class="mt-4 flex flex-col gap-4">
        {s.entries.map((e) => (
          <article class="rounded-xl border border-black/10 dark:border-white/10 bg-white/60 dark:bg-white/[0.02] p-5 shadow-sm">
            <header class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between">
              <h3 class="font-serif text-base font-semibold text-[color:var(--color-accent)] dark:text-[color:var(--color-accent-dark)]" set:html={inlineMd(e.title)}></h3>
              <span class="text-sm text-[color:var(--color-muted)] dark:text-[color:var(--color-muted-dark)] italic">{e.dates}</span>
            </header>
            <div class="mt-0.5 flex flex-col gap-0.5 sm:flex-row sm:items-baseline sm:justify-between">
              <p class="text-sm italic text-[color:var(--color-ink)]/80 dark:text-[color:var(--color-ink-dark)]/80" set:html={inlineMd(e.org)}></p>
              <span class="text-sm italic text-[color:var(--color-muted)] dark:text-[color:var(--color-muted-dark)]">{e.location}</span>
            </div>
            {e.bullets?.length > 0 && (
              <ul class="mt-3 list-disc space-y-1.5 pl-5 text-sm text-[color:var(--color-ink)]/90 dark:text-[color:var(--color-ink-dark)]/90">
                {e.bullets.map((b) => <li set:html={inlineMd(b)} />)}
              </ul>
            )}
          </article>
        ))}
      </div>
    </section>
  ))}

  <section class="mt-10">
    <h2 class="font-serif text-xl font-semibold text-[color:var(--color-accent)] dark:text-[color:var(--color-accent-dark)]">
      Professional Development & Training
    </h2>
    <ul class="mt-3 list-disc space-y-1.5 pl-5 text-[color:var(--color-ink)]/90 dark:text-[color:var(--color-ink-dark)]/90">
      {cv.training.map((t) => <li set:html={inlineMd(t)} />)}
    </ul>
  </section>

  <section class="mt-10">
    <h2 class="font-serif text-xl font-semibold text-[color:var(--color-accent)] dark:text-[color:var(--color-accent-dark)]">
      Skills
    </h2>
    <dl class="mt-3 grid grid-cols-1 gap-3 sm:grid-cols-[max-content_1fr] sm:gap-x-6 sm:gap-y-2">
      {cv.skills.map((s) => (
        <>
          <dt class="font-semibold text-[color:var(--color-ink)] dark:text-[color:var(--color-ink-dark)]">{s.label}</dt>
          <dd class="text-[color:var(--color-ink)]/90 dark:text-[color:var(--color-ink-dark)]/90" set:html={inlineMd(s.value)}></dd>
        </>
      ))}
    </dl>
  </section>

  <section class="mt-10">
    <h2 class="font-serif text-xl font-semibold text-[color:var(--color-accent)] dark:text-[color:var(--color-accent-dark)]">
      Grants, Scholarships & Honors
    </h2>
    <ul class="mt-3 list-disc space-y-1.5 pl-5 text-[color:var(--color-ink)]/90 dark:text-[color:var(--color-ink-dark)]/90">
      {cv.grants.map((g) => <li set:html={inlineMd(g)} />)}
    </ul>
  </section>

  <section class="mt-10">
    <h2 class="font-serif text-xl font-semibold text-[color:var(--color-accent)] dark:text-[color:var(--color-accent-dark)]">
      Languages
    </h2>
    <ul class="mt-3 flex flex-wrap gap-2">
      {cv.languages.map((l) => (
        <li class="rounded-full border border-black/10 dark:border-white/15 bg-black/[0.03] dark:bg-white/[0.06] px-3 py-1 text-sm text-[color:var(--color-ink)]/90 dark:text-[color:var(--color-ink-dark)]/90">{l}</li>
      ))}
    </ul>
  </section>
</BaseLayout>
